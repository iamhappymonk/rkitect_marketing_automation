# rkitect.ai Content Pipeline — Environment Variables
# Copy this file to .env and fill in real values.

# ── Anthropic (Claude) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenRouter ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ── Buffer ──────────────────────────────────────────
BUFFER_ACCESS_TOKEN=...
BUFFER_INSTAGRAM_PROFILE_ID=...
BUFFER_LINKEDIN_PROFILE_ID=...
BUFFER_TWITTER_PROFILE_ID=...
# BUFFER_REDDIT_PROFILE_ID=...     # Add once Reddit posting confirmed

# ── Dashboard ───────────────────────────────────────
DASHBOARD_PORT=5050
DASHBOARD_SECRET_KEY=change-me-to-something-random
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# ── Optional: Image Generation (via OpenRouter) ────
# Image briefs are generated as text prompts, then
# passed through an OpenRouter model for refinement.
# No separate image gen API needed for v2.

# ── Optional: Reddit (placeholder — uncomment once confirmed)
# REDDIT_CLIENT_ID=...
# REDDIT_CLIENT_SECRET=...
# REDDIT_USERNAME=...
# REDDIT_PASSWORD=...
# REDDIT_USER_AGENT=rkitect-pipeline:v2 (by /u/youruser)
