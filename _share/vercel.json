{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/landing" },
    { "source": "/v2", "destination": "/_astro/dist/index.html" },
    { "source": "/v2/", "destination": "/_astro/dist/index.html" },
    { "source": "/v2/:path*", "destination": "/_astro/dist/:path*" }
  ]
}
