---
export interface Props { currentPath?: string }
const { currentPath = '/' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: `${base}/product`, label: 'The studio', match: '/product' },
  { href: `${base}/about`, label: 'About', match: '/about' },
  { href: `${base}/contact`, label: 'Contact', match: '/contact' },
];
---
<nav class="container-page section-pad flex items-center justify-between py-6 md:py-8">
  <a href={`${base}/`} class="font-display text-lg md:text-xl tracking-tightish text-ink" aria-label="rkitect.ai home">
    rkitect<span class="text-redline">.</span>ai
  </a>
  <div class="hidden md:flex items-center gap-8">
    {links.map((l) => (
      <a
        href={l.href}
        class={`text-sm transition-colors ${currentPath === l.match ? 'text-ink' : 'text-ink-mute hover:text-ink'}`}
      >{l.label}</a>
    ))}
  </div>
  <a href={`${base}/contact`} class="btn btn-primary">
    <span class="dot"></span>
    <span>Request beta access</span>
  </a>
</nav>
<hr class="rule container-page" />
