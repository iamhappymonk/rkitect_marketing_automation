---
import type { RosterMember } from '../data/roster';
export interface Props { member: RosterMember; deep?: boolean }
const { member, deep = false } = Astro.props;
const isChief = member.role === 'chief';
---
<article
  data-stagger-item
  class={`group relative rounded-lg border p-6 md:p-7 transition-all duration-300 ease-out
    ${isChief ? 'bg-ink text-paper border-ink hover:bg-black' : 'bg-paper-elevated border-rule hover:border-ink hover:-translate-y-0.5 hover:shadow-[0_8px_28px_-12px_rgba(0,0,0,0.18)]'}`}
>
  <div class="flex items-start justify-between gap-3">
    <div class={`text-mono text-2xs uppercase tracking-eyebrow ${isChief ? 'text-redline' : 'text-ink-mute'}`}>
      {isChief ? 'The chief' : 'Specialist'}
    </div>
    {isChief && <div class="h-2 w-2 rounded-full bg-redline animate-pulse" />}
  </div>
  <h3 class={`mt-3 font-display text-xl md:text-2xl tracking-tightish ${isChief ? 'text-paper' : 'text-ink'}`}>
    {member.name}
  </h3>
  <p class={`mt-3 text-sm leading-relaxed ${isChief ? 'text-paper/80' : 'text-ink-mute'}`}>
    {member.craft}
  </p>

  {deep && (
    <div class={`mt-6 space-y-4 border-t pt-5 ${isChief ? 'border-paper/15' : 'border-rule'}`}>
      <div>
        <div class={`text-mono text-2xs uppercase tracking-eyebrow ${isChief ? 'text-paper/55' : 'text-ink-mute'}`}>When active</div>
        <p class={`mt-1.5 text-sm ${isChief ? 'text-paper/90' : 'text-ink-soft'}`}>{member.active}</p>
      </div>
      <div>
        <div class={`text-mono text-2xs uppercase tracking-eyebrow ${isChief ? 'text-paper/55' : 'text-ink-mute'}`}>What they leave behind</div>
        <p class={`mt-1.5 text-sm ${isChief ? 'text-paper/90' : 'text-ink-soft'}`}>{member.leaves}</p>
      </div>
    </div>
  )}
</article>
