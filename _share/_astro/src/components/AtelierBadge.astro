---
// Hero-only drafting stamp. Inspired by atelier-01-badge.svg motifs:
// double hairline frame · north-arrow tick · scale-bar · Inconsolata labels.
// NOT the cohort badge — public-safe, no "ATELIER 01" branding.
export interface Props { class?: string }
const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 320 400"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="A studio drafting stamp"
  class={className}
>
  <!-- outer hairline frame -->
  <rect x="0.5" y="0.5" width="319" height="399" fill="oklch(0.995 0.003 70)" stroke="oklch(0.22 0.01 70)" stroke-width="1" />
  <!-- inner hairline frame -->
  <rect x="10.5" y="10.5" width="299" height="379" fill="none" stroke="oklch(0.22 0.01 70)" stroke-width="0.5" />

  <!-- top label band -->
  <line x1="10" y1="50" x2="310" y2="50" stroke="oklch(0.22 0.01 70)" stroke-width="0.5" />
  <text x="160" y="36" text-anchor="middle" font-family="Inconsolata, monospace" font-size="11" letter-spacing="3.2" fill="oklch(0.22 0.01 70)">A STUDIO ON YOUR DESK</text>

  <!-- giant 01 numeral -->
  <text x="160" y="220" text-anchor="middle" font-family="Spectral, Georgia, serif" font-size="160" font-weight="400" fill="oklch(0.22 0.01 70)">01</text>

  <!-- redline tick under numeral -->
  <line x1="135" y1="235" x2="185" y2="235" stroke="oklch(0.55 0.18 25)" stroke-width="1.5" />

  <!-- caption -->
  <text x="160" y="265" text-anchor="middle" font-family="Spectral, Georgia, serif" font-style="italic" font-size="14" fill="oklch(0.42 0.01 70)">brief · scheme · render</text>

  <!-- bottom info band -->
  <line x1="10" y1="320" x2="310" y2="320" stroke="oklch(0.22 0.01 70)" stroke-width="0.5" />
  <text x="22" y="340" font-family="Inconsolata, monospace" font-size="9" letter-spacing="1.8" fill="oklch(0.42 0.01 70)">DRAWN BY</text>
  <text x="22" y="354" font-family="Inconsolata, monospace" font-size="11" fill="oklch(0.22 0.01 70)">THE STUDIO</text>
  <text x="298" y="340" text-anchor="end" font-family="Inconsolata, monospace" font-size="9" letter-spacing="1.8" fill="oklch(0.42 0.01 70)">SCALE</text>
  <text x="298" y="354" text-anchor="end" font-family="Inconsolata, monospace" font-size="11" fill="oklch(0.22 0.01 70)">1 : 1</text>

  <!-- north arrow (top-left corner) -->
  <g transform="translate(34 78)">
    <circle cx="0" cy="0" r="14" fill="none" stroke="oklch(0.22 0.01 70)" stroke-width="0.5" />
    <polygon points="0,-12 4,2 0,-2 -4,2" fill="oklch(0.22 0.01 70)" />
    <text x="0" y="-18" text-anchor="middle" font-family="Inconsolata, monospace" font-size="8" fill="oklch(0.22 0.01 70)">N</text>
  </g>

  <!-- scale bar (top-right corner) -->
  <g transform="translate(244 78)">
    <rect x="0" y="0" width="14" height="6" fill="oklch(0.22 0.01 70)" />
    <rect x="14" y="0" width="14" height="6" fill="none" stroke="oklch(0.22 0.01 70)" stroke-width="0.5" />
    <rect x="28" y="0" width="14" height="6" fill="oklch(0.22 0.01 70)" />
    <text x="21" y="22" text-anchor="middle" font-family="Inconsolata, monospace" font-size="8" fill="oklch(0.42 0.01 70)">0   1   2 m</text>
  </g>

  <!-- bottom-left tick -->
  <line x1="22" y1="378" x2="44" y2="378" stroke="oklch(0.22 0.01 70)" stroke-width="1" />
  <!-- bottom-right tick -->
  <line x1="276" y1="378" x2="298" y2="378" stroke="oklch(0.22 0.01 70)" stroke-width="1" />
</svg>
